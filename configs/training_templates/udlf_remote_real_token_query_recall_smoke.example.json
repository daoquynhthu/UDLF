{
  "description": "Remote smoke template for fixed K=4 real-token query recall. Replace data_path through a private config copy before launch.",
  "parameters": {
    "mode": "stage-a",
    "run_dir": "runs/udlf_remote_real_token_query_recall_smoke",
    "device": "cuda",
    "data_path": "<REMOTE_SAVED_TOKEN_DATASET>",
    "data_task": "real_query_recall",
    "train_split": "train",
    "validation_split": "validation",
    "data_column": "input_ids",
    "vocab_size": 50257,
    "seq_len": 36,
    "batch_size": 32,
    "max_steps": 200,
    "latent_slots": 16,
    "latent_dim": 128,
    "embed_dim": 128,
    "ff_multiplier": 2,
    "latent_heads": 4,
    "readout_heads": 4,
    "solver_steps": 4,
    "diffusion_mode": "fixed",
    "fixed_sigma": 0.01,
    "segment_len_min": 6,
    "segment_len_max": 12,
    "detach_state_between_segments": true,
    "learning_rate": 0.0015,
    "weight_decay": 0.0,
    "grad_clip": 1.0,
    "amp": true,
    "eval_every": 100,
    "eval_batches": 4,
    "intervention_shift_tokens": 6,
    "intervention_pair_trials": 4,
    "intervention_perturb_std": 0.2,
    "intervention_perturb_trials": 16,
    "intervention_mix_alpha": 0.1,
    "save_every": 100,
    "log_every": 25,
    "async_checkpoint": true,
    "metrics_flush_every": 10,
    "metrics_fsync_every": 0,
    "seed": 900
  }
}
