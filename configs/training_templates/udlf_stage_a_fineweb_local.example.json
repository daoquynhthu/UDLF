{
  "description": "Local GPU Stage A probe on a Hugging Face dataset saved with load_from_disk. Copy to a private local config and set data_path.",
  "parameters": {
    "mode": "stage-a",
    "run_dir": "runs/udlf_stage_a_fineweb_local",
    "data_path": "<LOCAL_DATA_ROOT>/datasets/fineweb_edu_50m",
    "train_split": "train",
    "validation_split": "validation",
    "data_column": "input_ids",
    "seed": 2026,
    "device": "cuda",
    "vocab_size": 50257,
    "seq_len": 128,
    "batch_size": 4,
    "steps": 20,
    "learning_rate": 0.0005,
    "weight_decay": 0.01,
    "grad_clip": 1.0,
    "latent_slots": 16,
    "latent_dim": 128,
    "embed_dim": 128,
    "ff_multiplier": 4,
    "latent_heads": 4,
    "readout_heads": 4,
    "solver_steps": 4,
    "diffusion_mode": "state_dependent",
    "sigma_min": 0.0001,
    "sigma_max": 0.02,
    "segment_len": 32,
    "detach_state_between_segments": true,
    "amp": true,
    "eval_every": 5,
    "eval_batches": 2,
    "save_every": 10
  }
}
